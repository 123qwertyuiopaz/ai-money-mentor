# ──────────────────────────────────────────────
# AI Money Mentor — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# NVIDIA NIM API key (get from https://integrate.api.nvidia.com)
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# NIM model to use (llama-3.1-70b-instruct recommended)
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# JWT secret (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-32-byte-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///./data/money_mentor.db

# App settings
APP_NAME=AI Money Mentor
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
